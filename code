import java.util.*;
class Main
{
    static int gcd(int a, int b)
    {
        if(a==0)
        {
            return b;
        }
        if(b==0)
        {
            return a;
        }
        else
        {
            return gcd(b, a%b);
        }
    }
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);
        int a = sc.nextInt();
        int b = sc.nextInt();
        System.out.println("Gcd : " + gcd(a,b));
    }
}
